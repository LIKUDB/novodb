{
  "data_root": "./data",
  "vm_url": "http://localhost:8428",
  "cache_mb": 256,
  "l2_cache_mb": 128,
  "workers": 8,
  "log_level": "info",
  "metrics_port": 9090,
  "raft_port": 7000,
  "raft_bind": "0.0.0.0:7000",
  "query_port": 8081,
  "admin_port": 8080,
  "query_user": "admin",
  "query_password": "change-me",
  "shard_count": 4,
  "replica_count": 1,
  "wal_segments": 4,
  "auto_cluster": false,

  "fast_startup": false,
  "lazy_index_loading": true,
  "preload_cache": false,
  "compress_large_docs": true,
  "skip_large_indexes": false,
  "use_streaming_wal": false,

  "max_shards_per_node": 64,
  "max_cluster_nodes": 32,
  "auto_scale_interval": 60,
  "prediction_window": 300,
  "min_shard_docs": 1000,
  "max_shard_docs": 5000000,
  "scale_up_cooldown": 120,
  "scale_down_cooldown": 300,
  "auto_merge_enabled": true,
  "auto_split_enabled": true,
  "predictive_scaling": false,
  "aggressive_scaling": false,
  "max_replicas": 3,
  "min_replicas": 1,

  "max_document_size": 16777216,
  "compress_threshold": 102400,
  "index_skip_threshold": 1000000,
  "large_doc_threshold": 5242880,

  "max_concurrent_queries": 100,
  "query_timeout": "30s",
  "transaction_timeout": "60s",
  "max_query_depth": 10,
  "max_batch_size": 1000,
  "rate_limit": 1000,

  "jwt_secret": "change-me-in-production",
  "token_expiry": "24h",
  "max_login_attempts": 5,
  "lockout_duration": "15m",
  "tls_enabled": false,
  "tls_cert_file": "",
  "tls_key_file": "",

  "flex_column": {
    "enabled": true,
    "document_cache_mb": 128,
    "columnar_index_enabled": true,
    "auto_detect_hot_fields": true,
    "materialized_views": true,
    "columnar_compression": "zstd",
    "max_columnar_fields": 64,
    "hot_field_threshold": 0.3,
    "worker_count": 4,
    "update_queue_size": 10000,
    "view_refresh_interval": "5m"
  }
}
